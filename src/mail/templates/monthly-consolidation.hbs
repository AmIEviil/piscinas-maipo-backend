<h2>📅 Consolidación Mensual — {{mesNombre}}</h2>

<div class="info-box">
  Total mantenciones: <strong>{{totalMantenciones}}</strong> —
  <span class="badge-ok">✔ Realizadas: {{realizadas}}</span>&nbsp;
  <span class="badge-danger">✘ No realizadas: {{noRealizadas}}</span><br />
  <span style="margin-top:6px; display:inline-block;">Total facturado (realizadas): <strong>${{totalFacturado}}</strong></span>
</div>

<h3>📋 Mantenciones del mes</h3>
{{#if mantenciones}}
<table>
  <thead>
    <tr>
      <th>Fecha</th>
      <th>Cliente</th>
      <th>Ruta</th>
      <th>Realizada</th>
      <th>Valor</th>
    </tr>
  </thead>
  <tbody>
    {{#each mantenciones}}
    <tr>
      <td>{{fecha}}</td>
      <td><strong>{{cliente}}</strong></td>
      <td>{{ruta}}</td>
      <td>
        {{#if realizada}}
          <span class="badge-ok">✔ Sí</span>
        {{else}}
          <span class="badge-danger">✘ No</span>
        {{/if}}
      </td>
      <td>${{valor}}</td>
    </tr>
    {{/each}}
  </tbody>
</table>
{{else}}
<p style="color:#707070;">Sin mantenciones registradas para este mes.</p>
{{/if}}

<hr class="divider" />

<h3>🧴 Inventario de Productos</h3>
{{#if productos}}
<table>
  <thead>
    <tr>
      <th>Producto</th>
      <th>Tipo</th>
      <th>Usado en el mes</th>
      <th>Stock actual</th>
      <th>Estado</th>
    </tr>
  </thead>
  <tbody>
    {{#each productos}}
    <tr>
      <td><strong>{{nombre}}</strong></td>
      <td>{{tipo}}</td>
      <td style="text-align:center;">{{usadoEnMes}}</td>
      <td style="text-align:center;">{{cantDisponible}}</td>
      <td>
        {{#if recomendarCompra}}
          <span class="badge-warn">⚠ Comprar</span>
        {{else}}
          <span class="badge-ok">OK</span>
        {{/if}}
      </td>
    </tr>
    {{/each}}
  </tbody>
</table>
{{#if hayProductosAComprar}}
<div class="alert-box" style="margin-top:16px;">
  <strong>⚠ Se recomienda reponer:</strong>
  {{#each productosAComprar}}{{nombre}}{{#unless @last}}, {{/unless}}{{/each}}
</div>
{{/if}}
{{else}}
<p style="color:#707070;">Sin datos de productos.</p>
{{/if}}

<hr class="divider" />

<h3>💳 Cuentas Pendientes de Pago</h3>
{{#if hayPendientes}}
<div class="alert-box">
  Clientes con deuda: <strong>{{totalClientesPendientes}}</strong> — Total adeudado: <strong>${{totalPendienteGlobal}}</strong>
</div>
<table>
  <thead>
    <tr>
      <th>Cliente</th>
      <th>Dirección</th>
      <th>Día mantención</th>
      <th>Ruta</th>
      <th>Mant. pendientes</th>
      <th>Total adeudado</th>
    </tr>
  </thead>
  <tbody>
    {{#each clientesPendientes}}
    <tr>
      <td><strong>{{nombre}}</strong></td>
      <td>{{direccion}}</td>
      <td>{{dia_mantencion}}</td>
      <td>{{ruta}}</td>
      <td style="text-align:center;"><span class="badge-warn">{{mantencionesPendientes}}</span></td>
      <td><strong>${{totalPendiente}}</strong></td>
    </tr>
    {{/each}}
  </tbody>
</table>
{{else}}
<div class="success-box">
  <strong>✅ Sin deudas pendientes</strong><br />
  Estamos al día con todas las cuentas.
</div>
{{/if}}

<p style="margin-top:24px; color:#707070; font-size:12px;">Este informe se genera automáticamente el primer día de cada mes a las 9:00 AM.</p>
