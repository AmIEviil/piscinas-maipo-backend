<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <style>
    body { font-family: Arial, Helvetica, sans-serif; background: #dce8f0; margin: 0; padding: 0; }

    .wrapper { max-width: 620px; margin: 32px auto; border-radius: 10px; overflow: hidden; box-shadow: 0 4px 20px rgba(0,0,0,0.15); }

    /* Top accent strip */
    .topbar-accent { background: #1a1a1a; height: 5px; }

    /* Header / Topbar */
    .header { background: #0289c7; padding: 28px 36px; }
    .header h1 { color: #ffffff; margin: 0; font-size: 22px; font-weight: 700; letter-spacing: 0.4px; }
    .header p { color: rgba(255,255,255,0.75); margin: 5px 0 0; font-size: 11px; text-transform: uppercase; letter-spacing: 1.2px; }

    /* Body */
    .body { background: #ffffff; padding: 36px; color: #2b2b2b; line-height: 1.75; }
    .body h2 { color: #0289c7; margin-top: 0; font-size: 20px; padding-bottom: 12px; border-bottom: 2px solid #e4eef4; }
    .body h3 { color: #1a1a1a; font-size: 15px; margin-top: 30px; margin-bottom: 8px; }
    .body p { margin: 10px 0; }

    /* Buttons */
    .btn { display: inline-block; padding: 13px 30px; background: #0289c7; color: #ffffff !important; text-decoration: none; border-radius: 6px; margin: 20px 0; font-weight: bold; font-size: 15px; letter-spacing: 0.3px; }

    /* Tables */
    table { width: 100%; border-collapse: collapse; margin-top: 16px; font-size: 13px; }
    th { background: #0289c7; color: #ffffff; padding: 11px 14px; text-align: left; font-weight: 600; }
    td { padding: 10px 14px; border-bottom: 1px solid #e4eef4; color: #2b2b2b; vertical-align: top; }
    tr:last-child td { border-bottom: none; }
    tr:nth-child(even) td { background: #f5fafd; }

    /* Badges */
    .badge-warn   { display: inline-block; background: #FFF3E0; color: #E65100; padding: 3px 10px; border-radius: 12px; font-size: 12px; font-weight: bold; }
    .badge-ok     { display: inline-block; background: #E8F5E9; color: #2e7d32; padding: 3px 10px; border-radius: 12px; font-size: 12px; font-weight: bold; }
    .badge-danger { display: inline-block; background: #FFEBEE; color: #c62828; padding: 3px 10px; border-radius: 12px; font-size: 12px; font-weight: bold; }

    /* Callout boxes */
    .info-box    { background: #f0f8ff; border-left: 4px solid #0289c7; padding: 14px 18px; border-radius: 0 6px 6px 0; margin: 18px 0; }
    .alert-box   { background: #FFF8F0; border-left: 4px solid #E65100; padding: 14px 18px; border-radius: 0 6px 6px 0; margin: 18px 0; }
    .success-box { background: #F0FBF2; border-left: 4px solid #2e7d32; padding: 14px 18px; border-radius: 0 6px 6px 0; margin: 18px 0; }

    /* Divider */
    .divider { border: none; border-top: 2px solid #e4eef4; margin: 28px 0; }

    /* Footer — no-reply notice */
    .footer-noreply { background: #0289c7; padding: 14px 36px; text-align: center; }
    .footer-noreply p { color: rgba(255,255,255,0.92); font-size: 12px; margin: 0; }

    /* Footer — bottom info */
    .footer-bottom { background: #1a1a1a; padding: 20px 36px; text-align: center; }
    .footer-bottom p { color: #b7b7b7; font-size: 11px; margin: 4px 0; line-height: 1.6; }
    .footer-bottom .company { color: #ffffff; font-size: 13px; font-weight: bold; margin-bottom: 6px; }
  </style>
</head>
<body>
  <div class="wrapper">

    <!-- Topbar accent -->
    <div class="topbar-accent"></div>

    <!-- Header -->
    <div class="header">
      <h1>🏊 Piscinas El Maipo</h1>
      <p>Sistema de Gestión — Correo Automático</p>
    </div>

    <!-- Content -->
    <div class="body">
      {{{body}}}
    </div>

    <!-- No-reply notice -->
    <div class="footer-noreply">
      <p>⚠ Este es un correo generado automáticamente. <strong>Por favor no respondas a este mensaje.</strong></p>
    </div>

    <!-- Footer -->
    <div class="footer-bottom">
      <p class="company">Piscinas El Maipo</p>
      <p>Sistema automatizado de notificaciones internas</p>
      <p style="margin-top:10px; color:#535353; font-size:10px;">Si crees que recibiste este correo por error, puedes ignorarlo con seguridad.</p>
    </div>

  </div>
</body>
</html>
